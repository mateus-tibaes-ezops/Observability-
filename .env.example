# ============================================================
# VARIÁVEIS DE AMBIENTE
# ============================================================
# Copie este arquivo para .env e configure com seus valores
# IMPORTANTE: Nunca commita .env com secrets reais no Git!

# ========== GRAFANA ==========
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=admin
GRAFANA_PROVISIONING_ENABLED=true

# ========== PROMETHEUS ==========
PROMETHEUS_SCRAPE_INTERVAL=15s
PROMETHEUS_EVALUATION_INTERVAL=15s

# ========== NOTIFIER -> SLACK ==========
# Webhook real opcional. Se vazio, o envio para Slack sera ignorado.
SLACK_WEBHOOK_URL=
SLACK_CHANNEL=#alerts-infra

# ========== ALERTMANAGER ==========
ALERTMANAGER_ENABLED=true
ALERTMANAGER_PORT=9093
ALERTMANAGER_RETENTION_HOURS=720

# ========== NOTIFIER -> DISCORD ==========
# Webhook real opcional. Se vazio, o envio para Discord sera ignorado.
DISCORD_WEBHOOK_URL=
DISCORD_CHANNEL=alerts

# ========== LOGGING ==========
LOG_LEVEL=info
